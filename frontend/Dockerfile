FROM node:22-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY nginx-api-proxy.conf.template /etc/nginx/templates/default.conf.template
ENV BACKEND_HOST=sample-backend:8080
EXPOSE 80
